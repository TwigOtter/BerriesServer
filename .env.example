# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ── ingest_api ────────────────────────────────────────────────────────────
INGEST_HOST=0.0.0.0
INGEST_PORT=8000
INGEST_SECRET=your_shared_secret_here   # set the same value in Streamer.bot requests

# ── LLM backend ───────────────────────────────────────────────────────────
LLM_BACKEND=anthropic                   # "anthropic" or "ollama"
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Discord ───────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token
DISCORD_BERRIES_CHANNEL_WHITELIST_IDS=123456789,987654321   # comma-separated channel IDs; Berries skips the 2-message redirect check here (e.g. #berries-chat, debug channel)
DISCORD_WATCH_CHANNEL_IDS=123456789               # comma-separated channel IDs; messages are chunked and embedded into ChromaDB
DISCORD_BERRIES_CHAT_CHANNEL_ID=123456789         # dedicated channel for conversations with Berries; redirected here when busy
DISCORD_ANNOUNCE_CHANNEL_ID=123456789             # channel for going-live and movie night announcements
DISCORD_BOT_WEBHOOK_PORT=8002                     # port for the discord_bot's internal webhook server
DISCORD_BOT_WEBHOOK_URL=http://127.0.0.1:8002     # ingest_api uses this to forward going-live events
DISCORD_EVENT_ROLE_ID=123456789                   # role pinged for movie night announcements (@Event Notifications)
DISCORD_STREAM_ROLE_ID=123456789                  # role pinged for going-live announcements (@Stream Notifications)
DISCORD_STICKERS_ONLY_CHANNEL_IDS=123456789       # comma-separated channel IDs; non-sticker messages are deleted and rules sticker is posted
DISCORD_RULES_STICKER_ID=123456789                # ID of the rules sticker to post after deleting a violation (right-click sticker → Copy Sticker ID)

# ── OMDb API (free at omdbapi.com) ────────────────────────────────────────
OMDB_API_KEY=your_omdb_api_key

# ── Giphy API (free at developers.giphy.com) ──────────────────────────────
GIPHY_API_KEY=your_giphy_api_key

# ── Twitch / Streamer.bot ─────────────────────────────────────────────────
STREAMERBOT_CALLBACK_URL=http://your-streamerbot-host:port/endpoint
STREAMERBOT_BERRIES_ACTION_NAME=ActionNameInStreamerBot
TWITCH_CHANNEL=your_twitch_channel_name

# ── Embedding model (local, no API key needed) ─────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Chunking tuning ────────────────────────────────────────────────────────
CHUNK_TOKEN_LIMIT=480
CHUNK_TIMEOUT_SEC=300
CHUNK_OVERLAP_SEC=30                # Twitch: seconds of messages to carry over after a flush
DISCORD_CHUNK_OVERLAP_MESSAGES=5   # Discord: number of messages to carry over after a flush
