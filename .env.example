# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.
#
# Tuning parameters (ports, model names, chunk sizes, etc.) have sensible
# defaults in shared/config.py and do not need to be set here.

# ── Secrets ───────────────────────────────────────────────────────────────
INGEST_SECRET=your_shared_secret_here       # set the same value in Streamer.bot requests
ANTHROPIC_API_KEY=sk-ant-...                # sign up at https://console.anthropic.com/api-keys
DISCORD_TOKEN=your_discord_bot_token        # create a bot at https://discord.com/developers/applications → Bot → Add Bot → copy the token
OMDB_API_KEY=your_omdb_api_key              # free at omdbapi.com
GIPHY_API_KEY=your_giphy_api_key            # free at developers.giphy.com

# ── Twitch / Streamer.bot ─────────────────────────────────────────────────
TWITCH_CHANNEL=your_twitch_channel_name
STREAMERBOT_CALLBACK_URL=http://your-streamerbot-host:port/endpoint
STREAMERBOT_BERRIES_ACTION_NAME=HandleBerriesEvent

# ── Discord IDs ───────────────────────────────────────────────────────────
DISCORD_BERRIES_CHANNEL_WHITELIST_IDS=123456789,987654321   # Berries skips the 2-message redirect check here
DISCORD_WATCH_CHANNEL_IDS=123456789                         # messages chunked and embedded into ChromaDB
DISCORD_BERRIES_CHAT_CHANNEL_ID=123456789                   # dedicated Berries chat channel; others are redirected here
DISCORD_ANNOUNCE_CHANNEL_ID=123456789                       # going-live and movie night announcements
DISCORD_LOG_CHANNEL_ID=123456789                            # LLM call logs (optional; leave blank to disable)
DISCORD_EVENT_ROLE_ID=123456789                             # role pinged for movie night (@Event Notifications)
DISCORD_STREAM_ROLE_ID=123456789                            # role pinged for going-live (@Stream Notifications)
DISCORD_STICKERS_ONLY_CHANNEL_IDS=123456789                 # non-sticker messages deleted; rules sticker posted
DISCORD_RULES_STICKER_ID=123456789                          # sticker posted after a violation (right-click → Copy Sticker ID)
