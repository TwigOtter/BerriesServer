# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ── ingest_api ────────────────────────────────────────────────────────────
INGEST_HOST=0.0.0.0
INGEST_PORT=8000
INGEST_SECRET=your_shared_secret_here   # set the same value in Streamer.bot requests

# ── LLM backend ───────────────────────────────────────────────────────────
LLM_BACKEND=anthropic                   # "anthropic" or "ollama"
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Discord ───────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token
DISCORD_BERRIES_CHANNEL_IDS=123456789,987654321   # comma-separated channel IDs

# ── Twitch / Streamer.bot ─────────────────────────────────────────────────
STREAMERBOT_CALLBACK_URL=http://your-streamerbot-host:port/endpoint
TWITCH_CHANNEL=twigotter

# ── Embedding model (local, no API key needed) ─────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Chunking tuning ────────────────────────────────────────────────────────
CHUNK_TOKEN_LIMIT=480
CHUNK_TIMEOUT_SEC=300
CHUNK_OVERLAP_SEC=30
